# =============================================
# HMR-BiLSTM Project .gitignore
# =============================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/

# ---------- Virtual Environments ----------
.venv/
venv/
env/
ENV/

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo
*~
.spyderproject
.spyproject

# ---------- OS ----------
Thumbs.db
.DS_Store
desktop.ini

# ---------- Data (large raw files) ----------
data/raw/*.csv

# ---------- Processed data (reproducible, large) ----------
data/processed/*.npz
data/processed/*.npy

# ---------- Model checkpoints (large binary) ----------
results/checkpoints/*.pt
results/ablation/checkpoints/*.pt

# ---------- Temporary / utility ----------
check_progress.py
tempCodeRunnerFile.py
*.log
